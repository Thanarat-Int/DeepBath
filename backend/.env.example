# ============================================================================
#  AutoX-SCB AI · Backend Environment
# ----------------------------------------------------------------------------
#  Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=AutoX-SCB-AI
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── Typhoon (primary LLM) ────────────────────────────────────────────────────
# Free tier — get a key at https://opentyphoon.ai (email only, no credit card).
# Rate limits per docs.opentyphoon.ai/en/rate-limits :  5 RPS / 200 RPM each.
TYPHOON_API_KEY=replace-me
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_CHAT_MODEL=typhoon-v2.5-30b-a3b-instruct   # reasoning, advisor, finalize
TYPHOON_FAST_MODEL=typhoon-v2.1-12b-instruct       # routing, classification

# ── Fallback LLM (optional - for offline demo) ───────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ── Database ─────────────────────────────────────────────────────────────────
# Owner role — used by the app for normal CRUD (RAG ingest, etc.)
DATABASE_URL=postgresql+asyncpg://autox:autox_dev@localhost:5432/autox
# Read-only role — used ONLY by the Text-to-SQL agent (defense-in-depth).
# Even if the SQL validator is bypassed, Postgres itself rejects writes.
DATABASE_URL_RO=postgresql+asyncpg://autox_ro:autox_ro_dev@localhost:5432/autox

# Demo customer (hardcoded for the interview demo). Real deployment scopes
# this from the authenticated session.
DEMO_CUSTOMER_ID=C0001

# ── MCP server ───────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8765

# ── LangFuse ─────────────────────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── ASR ──────────────────────────────────────────────────────────────────────
# Two ways to use Typhoon ASR — Day 2 will support BOTH and let you toggle:
#   ASR_BACKEND=api    → call api.opentyphoon.ai (100 RPM free, no GPU needed)
#   ASR_BACKEND=local  → run scb10x/typhoon-asr-realtime via HuggingFace transformers
ASR_BACKEND=api
ASR_MODEL_API=typhoon-asr-realtime
ASR_MODEL_LOCAL=scb10x/typhoon-asr-realtime
ASR_DEVICE=cpu                  # cpu | cuda  (only used when ASR_BACKEND=local)

# ── Safety ───────────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
MAX_INPUT_TOKENS=4000
