# ============================================================================
#  AutoX-SCB AI · Backend Environment
# ----------------------------------------------------------------------------
#  Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=AutoX-SCB-AI
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── Typhoon (primary LLM) ────────────────────────────────────────────────────
# Get a free key at https://opentyphoon.ai
TYPHOON_API_KEY=replace-me
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_CHAT_MODEL=typhoon-v2-70b-instruct
TYPHOON_FAST_MODEL=typhoon-v2-8b-instruct       # cheaper for routing/classification

# ── Fallback LLM (optional - for offline demo) ───────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autox:autox_dev@localhost:5432/autox

# ── MCP server ───────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8765

# ── LangFuse ─────────────────────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── ASR ──────────────────────────────────────────────────────────────────────
ASR_MODEL=scb10x/typhoon-asr-realtime
ASR_DEVICE=cpu                  # cpu | cuda

# ── Safety ───────────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
MAX_INPUT_TOKENS=4000
